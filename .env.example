# Required for cloud dictation (free: https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Optional: for meeting transcription AI analysis
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: intent router's Claude engine (tone, translate, reply actions)
# https://console.anthropic.com/settings/keys — falls back to dictation if unset
ANTHROPIC_API_KEY=your_anthropic_api_key_here
